{
  "name": "negentropy-lab",
  "version": "7.6.0",
  "description": "Negentropy-Lab Gateway Server - 多Agent协作知识聊天系统",
  "main": "dist/server/index.js",
  "types": "dist/server/index.d.ts",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "dev:legacy": "tsx watch src/index.ts",
    "dev:colyseus": "tsx watch server/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:legacy\"",
    "build": "npm run build:legacy && npm run build:server",
    "build:legacy": "tsc -p tsconfig.build.json",
    "build:server": "tsc -p tsconfig.server.build.json",
    "build:clean": "rimraf dist && npm run build",
    "start": "node dist/server/index.js",
    "start:legacy": "node dist/index.js",
    "start:colyseus": "node dist/server/index.js",
    "test": "vitest",
    "test:authority": "vitest run --config vitest.authority.config.mjs",
    "test:authority:coverage": "vitest run --config vitest.authority.config.mjs --coverage",
    "test:jest": "jest",
    "test:all": "npm run test && npm run test:jest",
    "test:coverage": "vitest --coverage",
    "test:coverage:jest": "jest --coverage",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "clean": "rimraf dist node_modules/.vite node_modules/.vite-temp",
    "prepare": "husky",
    "check:constitution": "node scripts/constitution-check.js",
    "check:consistency": "node scripts/consistency-check.js --strict",
    "check:contract": "node scripts/contract-count-check.js",
    "check:contract:strict": "node scripts/contract-count-check.js --enforce",
    "check:contract:drift": "node scripts/contract-drift-audit.js --enforce",
    "check:integration:config": "tsx scripts/check-integration-config.ts",
    "report:contract:monthly": "node scripts/contract-monthly-summary.js",
    "report:testdebt:skip": "node scripts/skip-test-governance.js",
    "test:perf": "bash ./scripts/run-performance-tests.sh --quick",
    "report:perf:weekly": "node scripts/perf-weekly-report.js",
    "report:perf:trend": "node scripts/perf-trend-audit.js",
    "phase14:e2e": "tsx scripts/phase14-e2e-integration.ts",
    "phase14:perf": "tsx scripts/phase14-performance-baseline.ts",
    "phase15:grayscale": "tsx scripts/phase15-grayscale-rollout.ts",
    "ops:preflight": "bash ./scripts/deploy-preflight-check.sh --env staging",
    "ops:preflight:prod": "bash ./scripts/deploy-preflight-check.sh --env production --skip-tests",
    "ops:deploy:smoke": "tsx ./scripts/ops-production-smoke.ts",
    "ops:authority:report": "tsx ./scripts/authority-ops-report.ts",
    "ops:authority:recovery:drill": "tsx ./scripts/authority-recovery-drill.ts",
    "ops:authority:baseline": "tsx ./scripts/authority-performance-baseline.ts",
    "ops:authority:cluster:monitor": "tsx ./scripts/authority-cluster-monitoring.ts",
    "ops:authority:cluster:validate": "tsx ./scripts/authority-cluster-validation.ts",
    "ops:authority:cluster:rehearshal": "tsx ./scripts/authority-cluster-rehearshal.ts",
    "ops:authority:staging:up": "docker compose -f docker-compose.authority-staging.yml up -d --build",
    "ops:authority:staging:down": "docker compose -f docker-compose.authority-staging.yml down -v",
    "ops:rollback:verify": "bash ./scripts/rollback-verify.sh",
    "ops:fault:injection": "tsx ./scripts/ops-fault-injection.ts",
    "launch": "tsx scripts/launcher-cli.ts",
    "launch:dev": "tsx scripts/launcher-cli.ts start --mode=dev",
    "launch:staging": "tsx scripts/launcher-cli.ts start --mode=staging",
    "launch:prod": "tsx scripts/launcher-cli.ts start --mode=production",
    "launch:status": "tsx scripts/launcher-cli.ts status",
    "launch:health": "tsx scripts/launcher-cli.ts health",
    "launch:ci-smoke": "tsx scripts/launcher-ci-smoke.ts",
    "gate:cluster:acceptance": "bash ./scripts/cluster-websocket-gate.sh",
    "test:gateway:mainline": "vitest run server/gateway/auth/test/auth-integration.test.ts server/gateway/llm/__tests__/*.test.ts server/gateway/llm/adapters/__tests__/*.test.ts server/gateway/openclaw-orchestration/__tests__/*.test.ts server/gateway/openclaw-decision/__tests__/*.test.ts server/gateway/resilience/__tests__/*.test.ts",
    "test:cluster": "vitest run server/cluster/**/*.test.ts server/discovery/mdns/MDNSDiscoverer.test.ts",
    "test:cluster:e2e": "vitest run server/cluster/__tests__/cluster-e2e.test.ts server/cluster/__tests__/cluster-websocket-e2e.test.ts"
  },
  "dependencies": {
    "@colyseus/core": "^0.15.0",
    "@colyseus/monitor": "^0.15.0",
    "@colyseus/schema": "^2.0.0",
    "@colyseus/ws-transport": "^0.15.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "colyseus": "^0.15.0",
    "compression": "^1.7.4",
    "connect-redis": "^7.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-jwt": "^8.4.1",
    "express-session": "^1.17.3",
    "helmet": "^7.1.0",
    "inversify": "^6.0.2",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "multicast-dns": "^7.2.5",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "ws": "^8.14.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/chai": "^4.3.11",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.17.10",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.6",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/coverage-v8": "^1.2.0",
    "chai": "^4.3.10",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "socket.io-client": "^4.8.3",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "keywords": [
    "gateway",
    "websocket",
    "colyseus",
    "agent",
    "llm",
    "chat",
    "realtime",
    "negentropy"
  ],
  "author": "Negentropy-Lab Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wsman/Negentropy-Lab.git"
  }
}
