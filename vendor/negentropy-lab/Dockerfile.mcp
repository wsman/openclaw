# 逆熵实验室 - MCP核心服务 Dockerfile
# 版本: v3.1.0
# 宪法约束: 基础设施宪法第1条 - 容器低熵
# 设计目标: 基于Node.js构建，集成TypeScript编译

# ========== 第一阶段: 构建阶段 (Builder) ==========
FROM node:22-alpine AS builder

# 宪法约束: 使用中国镜像源加速构建
RUN npm config set registry https://registry.npmmirror.com

WORKDIR /app

# 复制依赖清单
COPY package*.json ./
COPY config/system/tsconfig.json ./config/system/

# 安装所有依赖（包括开发依赖，用于构建）
RUN npm ci && npm cache clean --force

# 确保安装jest类型定义，用于TypeScript编译
RUN npm install --no-save @types/jest

# 复制源代码
COPY server ./server
COPY engine ./engine
COPY storage/config ./storage/config
# COPY scripts/legacy_app_scripts ./scripts   # 此目录不存在，注释掉
# COPY storage/knowledge/data/bindings.json ./storage/knowledge/data/  # 路径已不存在，注释掉

# 构建TypeScript代码
RUN npm run build

# 修复dist目录位置（如果构建输出到了config/system/dist）
RUN if [ -d "config/system/dist" ]; then \
    echo "Moving dist directory from config/system/dist to /app/dist" && \
    mv config/system/dist dist && \
    rmdir -p config/system 2>/dev/null || true; \
fi

# 移除开发依赖，只留下生产依赖
RUN npm prune --production

# ========== 第二阶段: 运行阶段 (Runner) ==========
FROM node:22-alpine AS runner

# 安装Python 3和相关依赖 (用于Python worker)
RUN apk add --no-cache python3 py3-pip && \
    ln -sf python3 /usr/bin/python

# 安装最小化Python依赖（仅支持Python worker的基本功能）
# 使用--break-system-packages绕过PEP 668限制
RUN python3 -m pip install --upgrade pip --break-system-packages && \
    pip3 install --no-cache-dir --break-system-packages \
        numpy \
        requests \
        prometheus-client \
        python-dotenv \
        ujson \
        sentence-transformers \
        && echo "Python minimal dependencies installed"

# 宪法约束: 创建非root用户，降低权限熵增
RUN addgroup -g 1001 -S negentropy && \
    adduser -u 1001 -S negentropy -G negentropy && \
    mkdir -p /app && \
    chown -R negentropy:negentropy /app

WORKDIR /app

# 从构建阶段复制已构建的应用
COPY --from=builder --chown=negentropy:negentropy /app/dist ./dist
COPY --from=builder --chown=negentropy:negentropy /app/package*.json ./
COPY --from=builder --chown=negentropy:negentropy /app/node_modules ./node_modules
COPY --from=builder --chown=negentropy:negentropy /app/storage ./storage

# 复制必要的配置文件
COPY --chown=negentropy:negentropy config/system/negentropy.yaml ./config/system/
COPY --chown=negentropy:negentropy config/environment/.env.example ./config/environment/.env

# 切换到非root用户
USER negentropy

# 暴露服务端口 (宪法约束: Layer 1.5 MCP核心服务端口)
EXPOSE 2567

# 健康检查 (符合基础设施宪法第2条 - 数据驱动)
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
    CMD node -e "const http = require('http'); const req = http.request('http://localhost:2567/health', {timeout: 5000}, (res) => {process.exit(res.statusCode === 200 ? 0 : 1)}); req.on('error', () => process.exit(1)); req.end()"

# 启动命令 (使用生产环境运行)
CMD ["node", "dist/index.js"]

# ========== 构建元数据 ==========
LABEL org.negentropy.lab.version="3.1.0"
LABEL org.negentropy.lab.layer="1.5"
LABEL org.negentropy.lab.component="mcp-core"
LABEL org.negentropy.lab.constitution.compliance="true"
